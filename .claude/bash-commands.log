import { NextResponse } from "next/server";
import { getLogtoContext } from "@logto/next/server-actions";
import { logtoConfig, extractOrganizationId } from "@/lib/logto";
import { setSession } from "@/lib/session";

/**
 * Post-login handler
 * Extracts organization ID from Logto claims and stores in session
 */
export async function GET() {
  try {
    const { isAuthenticated, claims } = await getLogtoContext(logtoConfig);

    if (!isAuthenticated || !claims) {
      return NextResponse.redirect(`${logtoConfig.baseUrl}/api/auth/login`);
    }

    // Extract organization ID from claims
    const organizationId = extractOrganizationId(claims);

    if (!organizationId) {
      return NextResponse.redirect(
        `${logtoConfig.baseUrl}/auth/error?message=no_organization`,
      );
    }

    // Store organization ID in session for middleware
    // Note: Access token is managed by Logto's session
    await setSession({
      user: {
        id: claims.sub as string,
        email: (claims.email as string) || "",
        name: (claims.name as string) || "",
        role: "store_admin", // TODO: Get from Logto custom claims
      },
      organizationId,
    });

    // Redirect to admin dashboard
    return NextResponse.redirect(`${logtoConfig.baseUrl}/admin`);
  } catch (error) {
    console.error("Post-login error:", error);
    return NextResponse.redirect(
      `${logtoConfig.baseUrl}/auth/error?message=post_login_failed`,
    );
  }
}
