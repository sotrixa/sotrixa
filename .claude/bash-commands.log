/**
 * Session management using iron-session
 * Stores organization ID for tenant context
 * Access token managed by Logto via @logto/next
 */

import { getIronSession, type IronSession } from "iron-session";
import { cookies } from "next/headers";
import { env } from "@/lib/env";

export type UserRole =
  | "super_admin"
  | "store_admin"
  | "ecommerce_admin"
  | "warehouse_admin";

export interface SessionData {
  user?: {
    id: string;
    email: string;
    name: string;
    role: UserRole;
  };
  organizationId?: string;
}

/**
 * Session configuration for iron-session
 */
export const sessionOptions = {
  password: env.LOGTO_COOKIE_SECRET,
  cookieName: "dikrasin_session",
  cookieOptions: {
    secure: process.env.NODE_ENV === "production",
    httpOnly: true,
    sameSite: "lax" as const,
    maxAge: 60 * 60 * 24 * 7, // 7 days
  },
};

/**
 * Get session from cookies
 * Returns null if no session exists
 */
export async function getSession(): Promise<
  IronSession<SessionData> & SessionData
> {
  const cookieStore = await cookies();
  return getIronSession<SessionData>(cookieStore, sessionOptions);
}

/**
 * Set session data
 */
export async function setSession(data: SessionData): Promise<void> {
  const session = await getSession();
  session.user = data.user;
  session.organizationId = data.organizationId;
  await session.save();
}

/**
 * Clear session
 */
export async function clearSession(): Promise<void> {
  const session = await getSession();
  session.destroy();
}
