import { type NextRequest, NextResponse } from "next/server";
import { getLogtoContext } from "@logto/next/server-actions";
import { logtoConfig, extractOrganizationId } from "@/lib/logto";
import { db } from "../../src/db";
import { sql } from "drizzle-orm";

/**
 * Next.js middleware for authentication and tenant context
 *
 * CRITICAL: This middleware MUST run on every protected request to:
 * 1. Verify Logto authentication
 * 2. Set PostgreSQL tenant context (app.current_tenant_id)
 * 3. Enable Row-Level Security filtering
 *
 * Missing tenant context = data leak risk
 */

export async function middleware(request: NextRequest) {
  const { pathname } = request.nextUrl;

  // Skip auth routes
  if (pathname.startsWith("/api/auth/")) {
    return NextResponse.next();
  }

  try {
    // Get Logto context
    const { isAuthenticated, claims } = await getLogtoContext(logtoConfig);

    // Redirect to login if not authenticated
    if (!isAuthenticated || !claims) {
      const loginUrl = new URL("/api/auth/login", request.url);
      return NextResponse.redirect(loginUrl);
    }

    // Extract organization ID from claims
    const organizationId = extractOrganizationId(claims);

    if (!organizationId) {
      const loginUrl = new URL("/api/auth/login", request.url);
      return NextResponse.redirect(loginUrl);
    }

    // Set tenant context in PostgreSQL session
    // CRITICAL: This must happen for EVERY request
    try {
      await db.execute(
        sql`SET LOCAL app.current_tenant_id = ${organizationId}`,
      );
    } catch (error) {
      console.error("Failed to set tenant context:", error);
      return NextResponse.json(
        { error: "Failed to set tenant context" },
        { status: 500 },
      );
    }

    // Add tenant ID to request headers for downstream use
    const response = NextResponse.next();
    response.headers.set("x-tenant-id", organizationId);

    return response;
  } catch (error) {
    console.error("Middleware error:", error);
    return NextResponse.json(
      { error: "Authentication failed" },
      { status: 500 },
    );
  }
}

/**
 * Matcher configuration
 * Runs middleware on:
 * - /admin/* - Admin dashboard routes
 * - /api/* - API routes (except /api/auth/*)
 *
 * Does NOT run on:
 * - /api/auth/* - Authentication routes
 * - /_next/* - Next.js internals
 * - /favicon.ico, /public/* - Static assets
 */
export const config = {
  matcher: [
    /*
     * Match all request paths except:
     * - /api/auth/* (authentication routes)
     * - /_next/* (Next.js internals)
     * - /favicon.ico, /public/* (static files)
     */
    "/admin/:path*",
    "/api/:path*",
  ],
};
