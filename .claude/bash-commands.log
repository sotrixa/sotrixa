import LogtoClient, { type InteractionMode, Storage } from "@logto/node";
import { env } from "@/lib/env";

/**
 * Server-side storage implementation for Logto
 * Uses in-memory Map (single server instance)
 */
class ServerStorage implements Storage {
  private storage = new Map<string, string>();

  async getItem(key: string): Promise<string | null> {
    return this.storage.get(key) ?? null;
  }

  async setItem(key: string, value: string): Promise<void> {
    this.storage.set(key, value);
  }

  async removeItem(key: string): Promise<void> {
    this.storage.delete(key);
  }
}

/**
 * Create Logto client instance
 * Must be created per-request in server context
 */
export function createLogtoClient() {
  return new LogtoClient({
    endpoint: env.LOGTO_ENDPOINT,
    appId: env.LOGTO_APP_ID,
    appSecret: env.LOGTO_APP_SECRET,
    scopes: ["organizations", "email", "profile", "openid"],
    resources: [],
  }, {
    storage: new ServerStorage(),
  });
}

/**
 * Configuration for Logto authentication
 */
export const logtoConfig = {
  baseUrl: env.NEXT_PUBLIC_APP_URL,
  cookieSecret: env.LOGTO_COOKIE_SECRET,
  cookieSecure: process.env.NODE_ENV === "production",
};

/**
 * Get user info including organizations from access token
 */
export async function getUserInfo(accessToken: string) {
  try {
    const response = await fetch(`${env.LOGTO_ENDPOINT}/oidc/me`, {
      headers: {
        Authorization: `Bearer ${accessToken}`,
      },
    });

    if (!response.ok) {
      throw new Error("Failed to fetch user info");
    }

    return await response.json();
  } catch (error) {
    console.error("Error fetching user info:", error);
    throw error;
  }
}

/**
 * Extract organization ID from JWT token claims
 */
export function extractOrganizationId(
  claims: Record<string, unknown>,
): string | null {
  // Logto stores organization in "organizations" claim as array
  const organizations = claims.organizations as string[] | undefined;
  return organizations?.[0] ?? null;
}
EOF
