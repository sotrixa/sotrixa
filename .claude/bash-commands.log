import { type NextRequest, NextResponse } from "next/server";
import {
  handleSignIn as logtoHandleSignIn,
  signIn,
  signOut,
} from "@logto/next/server-actions";
import { logtoConfig, extractOrganizationId } from "@/lib/logto";
import { setSession, clearSession } from "@/lib/session";
import { redirect } from "next/navigation";

/**
 * Logto authentication routes
 * Handles: /api/auth/login, /api/auth/callback, /api/auth/logout
 */

export async function GET(
  request: NextRequest,
  { params }: { params: Promise<{ logto: string[] }> },
) {
  const { logto } = await params;
  const action = logto[0];

  try {
    switch (action) {
      case "login":
        await signIn(logtoConfig);
        return NextResponse.json({ success: true });
      case "callback":
        return handleCallback(request);
      case "logout":
        await signOut(logtoConfig);
        return NextResponse.json({ success: true });
      default:
        return NextResponse.json(
          { error: "Invalid auth action" },
          { status: 400 },
        );
    }
  } catch (error) {
    console.error("Auth error:", error);
    return NextResponse.json(
      { error: "Authentication failed" },
      { status: 500 },
    );
  }
}

export async function POST(
  request: NextRequest,
  { params }: { params: Promise<{ logto: string[] }> },
) {
  return GET(request, { params });
}

/**
 * Handle Logto callback after authentication
 * Extracts JWT, organization ID, and stores in session
 */
async function handleCallback(request: NextRequest) {
  const searchParams = request.nextUrl.searchParams;

  try {
    // Handle Logto callback
    await logtoHandleSignIn(logtoConfig, searchParams);

    // TODO: Get claims and extract organization ID
    // The current @logto/next/server-actions doesn't expose claims directly
    // We need to use getLogtoContext after sign-in to get the claims
    // For now, redirect to a handler that will extract the org ID

    redirect("/api/auth/post-login");
  } catch (error) {
    console.error("Callback error:", error);
    return NextResponse.redirect(
      `${logtoConfig.baseUrl}/auth/error?message=callback_failed`,
    );
  }
}
